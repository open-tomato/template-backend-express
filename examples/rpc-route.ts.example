// Opt-in example: minimal JSON-RPC 2.0 handler.
//
// Copy this file to `src/routes/rpc.ts` (drop the `.example` suffix), then
// mount it from `src/index.ts`:
//
//   import { rpcRouter, type RpcMethod } from './routes/rpc.js';
//   const methods: Record<string, RpcMethod> = {
//     'ping': async () => ({ pong: true }),
//   };
//   register(app) {
//     app.use('/rpc', rpcRouter(methods));
//   }
//
// No new dependencies are required — this uses only express + zod, both
// already in the template's package.json.

import type { Request, Response, Router as RouterType } from 'express';

import { Router } from 'express';
import { z } from 'zod';

const RpcRequestSchema = z.object({
  jsonrpc: z.literal('2.0'),
  id: z.union([z.string(), z.number(), z.null()]).optional(),
  method: z.string().min(1),
  params: z.unknown().optional(),
});

type RpcRequest = z.infer<typeof RpcRequestSchema>;

export type RpcMethod = (params: unknown) => Promise<unknown> | unknown;

interface RpcErrorBody {
  code: number;
  message: string;
  data?: unknown;
}

function rpcError(id: RpcRequest['id'] | undefined, error: RpcErrorBody): {
  jsonrpc: '2.0';
  id: RpcRequest['id'] | null;
  error: RpcErrorBody;
} {
  return { jsonrpc: '2.0', id: id ?? null, error };
}

export function rpcRouter(methods: Record<string, RpcMethod>): RouterType {
  const router = Router();

  router.post('/', async (req: Request, res: Response) => {
    const parsed = RpcRequestSchema.safeParse(req.body);
    if (!parsed.success) {
      res.status(400).json(rpcError(undefined, { code: -32600, message: 'Invalid Request' }));
      return;
    }

    const { id, method, params } = parsed.data;
    const handler = methods[method];
    if (!handler) {
      res.status(404).json(rpcError(id, { code: -32601, message: 'Method not found' }));
      return;
    }

    try {
      const result = await handler(params);
      res.json({ jsonrpc: '2.0', id: id ?? null, result });
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Internal error';
      res.status(500).json(rpcError(id, { code: -32603, message }));
    }
  });

  return router;
}
